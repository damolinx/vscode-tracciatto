{
  "name": "tracciatto",
  "displayName": "Tracciatto",
  "description": "A Ruby debugger built on top of rdbg, providing an integrated debugging experience with configurable behavior.",
  "author": "damolinx",
  "publisher": "damolinx",
  "license": "Apache-2.0",
  "version": "0.2.6",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/damolinx/vscode-tracciatto"
  },
  "bugs": {
    "url": "https://github.com/damolinx/vscode-tracciatto/issues"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Debuggers",
    "Programming Languages"
  ],
  "keywords": [
    "debug",
    "debugger",
    "rdbg",
    "ruby"
  ],
  "extensionPack": [
    "damolinx.formatto"
  ],
  "activationEvents": [
    "onDebugResolve:tracciatto",
    "onLanguage:ruby"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tracciatto.addException",
        "title": "Add Exception Filter",
        "category": "Tracciatto",
        "icon": "$(add)"
      },
      {
        "command": "tracciatto.attach",
        "title": "Attach to…",
        "category": "Tracciatto"
      },
      {
        "command": "tracciatto.debugFile",
        "title": "Debug Active Editor",
        "category": "Tracciatto",
        "enablement": "editorLangId == ruby"
      },
      {
        "command": "tracciatto.removeException",
        "title": "Remove Exception Filter",
        "category": "Tracciatto",
        "icon": "$(remove-close)"
      },
      {
        "command": "tracciatto.runFile",
        "title": "Run Active Editor",
        "category": "Tracciatto",
        "enablement": "editorLangId == ruby"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tracciatto.removeException",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "tracciatto.addException",
          "when": "view == tracciatto.exceptions && viewItem =~ /userGroup/",
          "group": "inline"
        },
        {
          "command": "tracciatto.removeException",
          "when": "view == tracciatto.exceptions && viewItem =~ /userException/",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "tracciatto.addException",
          "when": "view == tracciatto.exceptions",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "properties": {
        "tracciatto.debug.preferBundler": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Prefer running `bundle exec` when a Gemfile is present and no `runtimeExecutable` is explicitly set in the configuration file."
        },
        "tracciatto.debug.runtimeExecutable": {
          "type": "string",
          "default": "ruby",
          "description": "Path to the Ruby executable used for debugging."
        },
        "tracciatto.debug.skipPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Paths to skip when stepping in the Ruby debugger."
        },
        "tracciatto.debug.skipPathsFileName": {
          "type": "string",
          "default": ".tracciatto-filter",
          "description": "Filename containing skip path patterns. Each line contains a single pattern; lines starting with '#' are ignored."
        },
        "tracciatto.logDapMessages": {
          "type": "boolean",
          "default": false,
          "description": "Log Debug Adapter Protocol messages at trace level (for extension or DAP debugging)."
        }
      }
    },
    "breakpoints": [
      {
        "language": "ruby"
      }
    ],
    "debuggers": [
      {
        "type": "tracciatto",
        "label": "Ruby (tracciatto)",
        "languages": [
          "ruby"
        ],
        "configurationAttributes": {
          "attach": {
            "type": "object",
            "properties": {
              "localFs": {
                "type": "boolean",
                "description": "Enable local filesystem access support."
              },
              "localFsMap": {
                "type": "string",
                "description": "Map local filesystem paths to remote paths."
              },
              "port": {
                "type": "string",
                "description": "[host:]port path to the rdbg DAP server."
              },
              "rdbgPath": {
                "type": "string",
                "description": "Optional absolute path to rdbg."
              },
              "skipPaths": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Paths to skip when stepping."
              },
              "socket": {
                "type": "string",
                "description": "Socket path to the rdbg DAP server."
              },
              "socketTimeoutMs": {
                "type": "number",
                "default": 5000,
                "description": "Timeout in milliseconds for the rdbg socket to appear before failing."
              }
            }
          },
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "args": {
                "type": "array",
                "description": "Arguments passed to the Ruby program",
                "default": [],
                "items": {
                  "description": "Single argument",
                  "type": "string"
                }
              },
              "cwd": {
                "type": "string",
                "description": "Working directory",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "description": "Environment variables passed to the Ruby program",
                "default": {},
                "additionalProperties": {
                  "type": "string"
                }
              },
              "localFs": {
                "type": "boolean",
                "description": "Enable local filesystem access support."
              },
              "localFsMap": {
                "type": "string",
                "description": "Map local filesystem paths to remote paths."
              },
              "program": {
                "type": "string",
                "description": "Ruby file to debug",
                "default": "${file}"
              },
              "rdbgPath": {
                "type": "string",
                "description": "Optional absolute path to dbg"
              },
              "runtimeExecutable": {
                "type": "string",
                "description": "Ruby command to run",
                "default": "ruby"
              },
              "skipPaths": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Paths to skip when stepping."
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Tracciatto: Launch current file",
            "description": "Debug the currently open Ruby file",
            "body": {
              "type": "tracciatto",
              "request": "launch",
              "name": "Debug current file",
              "program": "^\"\\${file}\""
            }
          }
        ],
        "initialConfigurations": [
          {
            "type": "tracciatto",
            "name": "Debug current file",
            "request": "launch",
            "program": "${file}"
          },
          {
            "type": "tracciatto",
            "name": "Attach to rdbg",
            "request": "attach",
            "port": 12345
          }
        ]
      },
      {
        "type": "rdbg",
        "label": "Ruby (rdbg)",
        "languages": [
          "ruby"
        ],
        "configurationAttributes": {
          "attach": {
            "properties": {
              "debugPort": {
                "type": "string",
                "description": "[hostname:]port or socket path to the rdbg DAP server."
              },
              "localFs": {
                "type": "boolean",
                "description": "Enable local filesystem access support."
              },
              "localFsMap": {
                "type": "string",
                "description": "Map local filesystem paths to remote paths."
              },
              "rdbgPath": {
                "type": "string",
                "description": "Optional absolute path to dbg"
              },
              "showProtocolLog": {
                "type": "boolean",
                "description": "Log all DAP messages"
              }
            }
          },
          "launch": {
            "required": [
              "script"
            ],
            "properties": {
              "args": {
                "type": "array",
                "description": "Arguments passed to the Ruby program",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "command": {
                "type": "string",
                "description": "Command name (ruby, rake, bin/rails, bundle exec ruby, etc)",
                "default": "ruby"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "description": "Environment variables passed to the Ruby program",
                "default": {}
              },
              "localFs": {
                "type": "boolean",
                "description": "Enable local filesystem access support."
              },
              "localFsMap": {
                "type": "string",
                "description": "Map local filesystem paths to remote paths."
              },
              "rdbgPath": {
                "type": "string",
                "description": "Absolute path to rdbg"
              },
              "script": {
                "type": "string",
                "description": "Absolute path to a Ruby file.",
                "default": "${file}"
              },
              "showProtocolLog": {
                "type": "boolean",
                "description": "Log all DAP messages"
              },
              "useBundler": {
                "type": "boolean",
                "description": "Use `bundle exec` to run Ruby program",
                "default": false
              }
            }
          }
        }
      }
    ],
    "views": {
      "debug": [
        {
          "id": "tracciatto.exceptions",
          "name": "Exception Filters",
          "icon": "debug-alt"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run ts:check-types && npm run ts:compile",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "node ./out/test/runTest.js",
    "ts:check-types": "tsc --noEmit",
    "ts:compile": "tsc -p ./",
    "ts:watch": "tsc -w -p ./",
    "vsce-package": "vsce package",
    "vscode:prepublish": "npm run ts:check-types && node esbuild.mjs --production",
    "watch": "npm run ts:watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@stylistic/eslint-plugin": "^5.4.0",
    "@types/node": "^22",
    "@types/vscode": "~1.105",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vscode/test-electron": "^2.5.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.30.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "sinon": "^21.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.35.0",
    "vscode-debugprotocol": "^1.51.0"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "yauzl": "^3.2.1"
  }
}